      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tTNOuRcy1_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tTNOuRcy1_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "Claim Flow Anomaly Detection" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tMCPCor02_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tMCPCor02_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "Multi-Customer Correlation" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-Stage_jsrEfr-synthetic-wait-for-user-to-select-next-stage-task_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="Stage_jsrEfr-synthetic-wait-for-user-to-select-next-stage-task_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "Wait for User to Select Next Stage for Multi-Customer Investigation" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tBMXe7xGw_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tBMXe7xGw_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "Assess Affected Providers" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-Stage_ugoiTN-synthetic-wait-for-user-to-select-next-stage-task_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="Stage_ugoiTN-synthetic-wait-for-user-to-select-next-stage-task_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "Wait for User to Select Next Stage for Initial Response" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-unknownTaskFallbackEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="unknownTaskFallbackEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; !["Send Message to Channel","Wait for User to Select Next Stage for Closed","Litigation Defense Posture Review","Wait for User to Select Next Stage for Litigation Defense","Tri-Party Fiduciary Conflict Review","Wait for User to Select Next Stage for Fiduciary Review","BAA Boundary Analysis","Spawn Stakeholder Parent — Northstar Regional Health","Spawn Stakeholder Parent — Provider Alpha","Spawn Stakeholder Parent — Provider Beta","Spawn Stakeholder Parent — Provider Gamma","Spawn Stakeholder Parent — Provider Delta","Spawn Stakeholder Parent — Provider Epsilon","Wait for User to Select Next Stage for Regulatory Response","Vector Hypothesis Analysis","Forensic Self-Examination","Wait for User to Select Next Stage for Vector Isolation","Claim Flow Anomaly Detection","Multi-Customer Correlation","Wait for User to Select Next Stage for Multi-Customer Investigation","Assess Affected Providers","Wait for User to Select Next Stage for Initial Response"].includes(task.taskName))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
