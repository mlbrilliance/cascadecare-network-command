            </uipath:context>
            <uipath:input name="body" type="json" target="body"><![CDATA[{"body":{"tasksToCancel":"=js:(vars.caseManagerDecisions?.tasksToCancel ?? [])","traces":"=js:(vars.caseManagerDecisions?.traces ?? [])","messageReference":"=js:\"case-\" + metadata.InstanceId"}}]]></uipath:input>
