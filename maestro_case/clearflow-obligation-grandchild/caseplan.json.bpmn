              <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"caseDeterministicRules":{"type":"object"},"caseCurrentExecutionState":{"type":"object"}},"required":[]}]]></uipath:inputSchema>
