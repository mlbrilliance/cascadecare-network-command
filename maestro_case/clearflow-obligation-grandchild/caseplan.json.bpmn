            </uipath:context>
            <uipath:input name="ItemData" type="json" target="body"><![CDATA[{"upsertKeys":"=js:({ ...(vars.UpdatedEventsScriptResponse?.upsertKeys ?? {}) })","deleteKeys":"=js:([ ...(vars.UpdatedEventsScriptResponse?.deleteKeys ?? []) ])"}]]></uipath:input>
