Closure Audit Record","runOnlyOnce":false,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Obligation Discharged"]},"ruleName":"Entry rule 1"}]}]}],"version":1},"caseCurrentExecutionState":"=js:({ \"version\": 1, \"eventIdentifier\": vars.EventSubProcessEventIdentifier, \"event\": { \"type\": vars.EventSubProcessLatestEventType, \"parameters\": vars.EventSubProcessLatestEventParams, \"isExternal\": (vars.EventSubProcessLatestEventType == \"CaseEntered\" || vars.EventSubProcessLatestEventType == \"TaskCompleted\") ? false : true }, \"state\": { ...vars.caseState, \"vars\": { \"Classify Obligation\": { \"Error\": (vars.error), \"obligation_class\": (vars.obligationClass), \"severity\": (vars.severity), \"required_response\": (vars.requiredResponse), \"rationale\": (vars.rationale) }, \"Wait for User to Select Next Stage for Obligation Intake\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Prepare & File Obligation Response\": { \"ReviewerId\": (vars.reviewerId), \"ResponseDisposition\": (vars.responseDisposition), \"ResponseNarrative\": (vars.responseNarrative), \"FiledTimestamp\": (vars.filedTimestamp) }, \"Generate Audit Record\": { \"Error\": (vars.error7), \"audit_record_id\": (vars.auditRecordId), \"recorded_at\": (vars.recordedAt), \"disposition\": (vars.disposition), \"audit_summary\": (vars.auditSummary) }, \"Wait for User to Select Next Stage for Obligation Response\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Generate Closure Audit Record\": { \"Error\": (vars.error9), \"audit_record_id\": (vars.auditRecordId2), \"recorded_at\": (vars.recordedAt2), \"disposition\": (vars.disposition2), \"audit_summary\": (vars.auditSummary2) }, \"Wait for User to Select Next Stage for Obligation Discharged\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Received event params\": { \"response\": (vars.mainEventSubprocessResponse.connectorResponse) }, \"APIEvent\": (vars.mainEventSubprocessResponse.apiEvent) } } })"}]]></uipath:input>
