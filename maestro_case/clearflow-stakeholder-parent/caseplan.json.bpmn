            <uipath:output name="UserSelectStageMessageResponse" type="jsonSchema" var="UserSelectStageMessageResponse" custom="true"><![CDATA[=js:(vars.EventSubProcessLatestEventType == "TaskCompleted" && (vars.EventSubProcessLatestEventParams != null && vars.EventSubProcessLatestEventParams.taskName != null && =js:["Wait for User to Select Next Stage for Stakeholder Onboarding", "Wait for User to Select Next Stage for Impact Assessment", "Wait for User to Select Next Stage for Obligation Determination", "Wait for User to Select Next Stage for Stakeholder Resolved"].some((task) => task == vars.EventSubProcessLatestEventParams.taskName)) ? {} : vars.UserSelectStageMessageResponse)]]></uipath:output>
