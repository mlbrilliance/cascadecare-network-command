ty","runOnlyOnce":false,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Impact Assessment"]},"ruleName":"Stage entered"}]}]},{"name":"Obligation Determination","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["Impact Assessment"]},"ruleName":"Previous stage completed"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["BAA Boundary Analysis","Spawn Obligation Grandchild"]},"ruleName":"Stage complete"}],"tasks":[{"name":"BAA Boundary Analysis","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Obligation Determination"]},"ruleName":"Stage entered"}]},{"name":"Spawn Obligation Grandchild","runOnlyOnce":true,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Obligation Determination"]},"ruleName":"Stage entered"}]}]},{"name":"Stakeholder Resolved","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["Obligation Determination"]},"ruleName":"Previous stage completed"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["Generate Closure Audit Record"]},"ruleName":"Stakeholder closed"}],"tasks":[{"name":"Generate Closure Audit Record","runOnlyOnce":false,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["Stakeholder Resolved"]},"ruleName":"Entry rule 1"}]}]}],"version":1},"caseCurrentExecutionState":"=js:({ \"version\": 1, \"eventIdentifier\": vars.EventSubProcessEventIdentifier, \"event\": { \"type\": vars.EventSubProcessLatestEventType, \"parameters\": vars.EventSubProcessLatestEventParams, \"isExternal\": (vars.EventSubProcessLatestEventType == \"CaseEntered\" || vars.EventSubProcessLatestEventType == \"TaskCompleted\") ? false : true }, \"state\": { ...vars.caseState, \"vars\": { \"Register Stakeholder & Pull BAA\": { \"Error\": (vars.error3), \"stakeholder_id\": (vars.stakeholderId), \"baa_id\": (vars.baaId), \"onboarding_status\": (vars.onboardingStatus), \"registered_scope\": (vars.registeredScope) }, \"Wait for User to Select Next Stage for Stakeholder Onboarding\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Assess Claim Disruption & Liquidity\": { \"Error\": (vars.error7), \"disruption_score\": (vars.disruptionScore), \"impact_tier\": (vars.impactTier), \"liquidity_assessment\": (vars.liquidityAssessment), \"rationale\": (vars.rationale2) }, \"Medical Records Summarization & PHI Exposure Quantification\": { \"Error\": (vars.error4), \"affected_record_count\": (vars.affectedRecordCount), \"risk_classification\": (vars.riskClassification), \"clinical_summary\": (vars.clinicalSummary), \"exposure_scope\": (vars.exposureScope) }, \"Claim Denial Prevention & Resolution\": { \"Error\": (vars.error5), \"denial_root_causes\": (vars.denialRootCauses), \"at_risk_claim_count\": (vars.atRiskClaimCount), \"recommended_actions\": (vars.recommendedActions), \"revenue_at_risk_usd\": (vars.revenueAtRiskUsd) }, \"Prior Authorization Continuity\": { \"Error\": (vars.error6), \"pending_auth_count\": (vars.pendingAuthCount), \"continuity_risk\": (vars.continuityRisk), \"expedited_queue\": (vars.expeditedQueue), \"sla_breach_projection\": (vars.slaBreachProjection) }, \"Wait for User to Select Next Stage for Impact Assessment\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"BAA Boundary Analysis\": { \"Error\": (vars.error2), \"disclosure_position\": (vars.disclosurePosition), \"cross_baa_conflicts\": (vars.crossBaaConflicts), \"rationale\": (vars.rationale) }, \"Spawn Obligation Grandchild\": { \"Error\": (vars.error) }, \"Wait for User to Select Next Stage for Obligation Determination\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Generate Closure Audit Record\": { \"Error\": (vars.error8), \"audit_record_id\": (vars.auditRecordId), \"recorded_at\": (vars.recordedAt), \"disposition\": (vars.disposition), \"audit_summary\": (vars.auditSummary) }, \"Wait for User to Select Next Stage for Stakeholder Resolved\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Received event params\": { \"response\": (vars.mainEventSubprocessResponse.connectorResponse) }, \"APIEvent\": (vars.mainEventSubprocessResponse.apiEvent) } } })"}]]></uipath:input>
