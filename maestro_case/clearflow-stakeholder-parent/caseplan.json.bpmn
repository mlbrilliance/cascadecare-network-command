lect Next Stage for Impact Assessment\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"BAA Boundary Analysis\": { \"Error\": (vars.error2), \"disclosure_position\": (vars.disclosurePosition), \"cross_baa_conflicts\": (vars.crossBaaConflicts), \"rationale\": (vars.rationale) }, \"Spawn Obligation Grandchild\": { \"Error\": (vars.error) }, \"Wait for User to Select Next Stage for Obligation Determination\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Generate Closure Audit Record\": { \"Error\": (vars.error8), \"audit_record_id\": (vars.auditRecordId), \"recorded_at\": (vars.recordedAt), \"disposition\": (vars.disposition), \"audit_summary\": (vars.auditSummary) }, \"Wait for User to Select Next Stage for Stakeholder Resolved\": { \"selectedStage\": (vars.UserSelectStageMessageResponse) }, \"Received event params\": { \"response\": (vars.mainEventSubprocessResponse.connectorResponse) }, \"APIEvent\": (vars.mainEventSubprocessResponse.apiEvent) } } })"}]]></uipath:input>
