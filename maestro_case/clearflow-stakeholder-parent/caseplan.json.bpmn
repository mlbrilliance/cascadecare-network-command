    <bpmn:subProcess id="UserAdhocTrigger_Subprocess" name="UserAdhocTrigger Subprocess" triggeredByEvent="true">
      <bpmn:extensionElements>
        <uipath:variables version="v1" />
      </bpmn:extensionElements>
      <bpmn:startEvent id="UserAdhocTrigger_EventSubprocessStartEvent" isInterrupting="false">
        <bpmn:extensionElements>
          <uipath:event version="v1">
            <uipath:type value="Maestro.ReceiveMessageEvent" version="v1" />
            <uipath:context>
              <uipath:input name="name" type="string" value="UserAdhocTrigger" />
            </uipath:context>
            <uipath:input name="Reference" type="string" value="=js:&#34;case-&#34; + metadata.InstanceId" target="bodyField" />
            <uipath:output name="response" type="jsonSchema" source="=result" var="adhocTasksMessageEventSubprocessResponse" />
          </uipath:event>
        </bpmn:extensionElements>
        <bpmn:outgoing>edge_UserAdhocTrigger_EventSubprocessStartEvent-UserAdhocTrigger_SendMessageEvent</bpmn:outgoing>
        <bpmn:messageEventDefinition />
      </bpmn:startEvent>
      <bpmn:endEvent id="UserAdhocTrigger_SendMessageEvent">
        <bpmn:extensionElements>
          <uipath:event version="v1">
            <uipath:type value="Maestro.SendMessageEvent" version="v1" />
            <uipath:context>
              <uipath:input name="name" type="string" value="MainEventSubprocessMessage" />
              <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"Reference":{"type":"string","title":"Reference"},"SpecificContent":{"type":"object","title":"Item information"},"TimeToLive":{"type":"duration","title":"Time to live"}},"required":["Reference","name"]}]]></uipath:inputSchema>
            </uipath:context>
            <uipath:input name="ItemData" type="json" target="body"><![CDATA[{"SpecificContent":{"event":"UserAdhocTrigger","eventId":"=js:Array.from({ length: 16 }, () => Math.floor(Math.random() * 256).toString(16).padStart(2, '0')).join('')","taskNames":"=js:(vars.adhocTasksMessageEventSubprocessResponse != null && vars.adhocTasksMessageEventSubprocessResponse.taskNames != null) ? vars.adhocTasksMessageEventSubprocessResponse.taskNames : []"},"Reference":"=js:\"case-\" + metadata.InstanceId","Error":null,"TimeToLive":null}]]></uipath:input>
          </uipath:event>
        </bpmn:extensionElements>
        <bpmn:incoming>edge_UserAdhocTrigger_EventSubprocessStartEvent-UserAdhocTrigger_SendMessageEvent</bpmn:incoming>
        <bpmn:messageEventDefinition messageRef="mainEventSubprocessMessage" />
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="edge_UserAdhocTrigger_EventSubprocessStartEvent-UserAdhocTrigger_SendMessageEvent" sourceRef="UserAdhocTrigger_EventSubprocessStartEvent" targetRef="UserAdhocTrigger_SendMessageEvent" />
    </bpmn:subProcess>
    <bpmn:subProcess id="adhocCaseEventSubProcess" name="Event Subprocess" triggeredByEvent="true">
      <bpmn:extensionElements>
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:output name="Case ID" type="string" source="=js:metadata.ExternalId ?? &#34;&#34;" var="CaseId" custom="true" />
          <uipath:output name="latestCaseState" type="json" source="=js:vars.caseState" var="CaseLocalLatestCaseState" custom="true" />
