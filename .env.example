# CascadeCare Network Command — Environment Variables
# Copy to .env and fill in values:  cp .env.example .env
# Never commit .env — it is in .gitignore.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Anthropic (BYO-LLM for Agent Builder agents via UiPath LLM Gateway) ───────
ANTHROPIC_API_KEY=

# ── UiPath Automation Cloud ───────────────────────────────────────────────────
UIPATH_TENANT_URL=
UIPATH_CLIENT_ID=
UIPATH_CLIENT_SECRET=

# ── MCP API Keys ──────────────────────────────────────────────────────────────
# After filling in the keys below, run:  bash scripts/setup-mcps.sh
# (or: make setup-mcps)

# Context7: up-to-date library / SDK documentation
# Free key: https://context7.com/dashboard
CONTEXT7_API_KEY=

# Ref Tools: token-efficient documentation search (public + private docs)
# Get your URL and key from https://ref.tools → your dashboard
# Default public endpoint shown; replace with your account-specific URL if needed.
REF_MCP_URL=https://mcp.ref.tools/sse
REF_API_KEY=

# Exa: neural / semantic web search
# API key: https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Tavily: AI-optimised real-time web search
# API key: https://app.tavily.com/home
TAVILY_API_KEY=
