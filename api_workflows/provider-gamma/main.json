{
  "document": {
    "dsl": "1.0.0",
    "name": "provider-gamma \u2014 Claim Anomaly Event Emitter",
    "version": "0.0.1",
    "namespace": "cascadecare",
    "metadata": {
      "description": "Integration Service API Workflow for source_system 'provider-gamma'. Emits a 'provider-claim-anomaly' event payload (schema: specs/003-uipath-native/event-contracts/provider-claim-anomaly.json-schema.json) consumed by the Claim Flow Anomaly Detection Maestro Trigger (task tTNOuRcy1, stage Stage_jsrEfr). DEPLOY-TIME NOTE: the live Data Fabric read (ClaimTelemetry entity) and the Maestro Trigger emission are wired at deploy via 'uip api-workflow registry stub' against a live tenant. Here the payload is shaped from workflow inputs (Data Fabric defaults) by a JavaScript/Assign activity; the connector read is NOT hand-authored.",
      "variables": {
        "schema": {
          "format": "json",
          "document": {
            "type": "object",
            "properties": {
              "eventPayload": {
                "type": "object",
                "default": {}
              }
            },
            "title": "Variables"
          }
        }
      }
    }
  },
  "input": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "simulated_day": {
            "type": "integer",
            "default": 1
          },
          "claim_drop_pct": {
            "type": "number",
            "default": 44.0
          },
          "anomaly_score": {
            "type": "number",
            "default": 0.78
          },
          "business_continuity_runway_days": {
            "type": "integer",
            "default": 30
          }
        },
        "title": "Inputs"
      }
    }
  },
  "output": {
    "schema": {
      "format": "json",
      "document": {
        "type": "object",
        "properties": {
          "event_type": {
            "type": "string"
          },
          "source_system": {
            "type": "string"
          },
          "simulated_day": {
            "type": "integer"
          },
          "provider_id": {
            "type": "string"
          },
          "claim_drop_pct": {
            "type": "number"
          },
          "anomaly_score": {
            "type": "number"
          },
          "business_continuity_runway_days": {
            "type": "integer"
          }
        },
        "title": "Outputs"
      }
    }
  },
  "do": [
    {
      "Sequence_1": {
        "do": [
          {
            "WorkflowStart": {
              "set": "${Object.entries($workflow.definition?.document?.metadata?.variables?.schema?.document?.properties || {}).reduce((acc, [name, def]) => ({ ...acc, [name]: def?.default }), {}) }",
              "output": {
                "as": "${$input}"
              },
              "export": {
                "as": "{ ...$context, variables: { ...$context.variables, ...$output } }"
              },
              "metadata": {
                "activityType": "Assign",
                "displayName": "Workflow start",
                "fullName": "Assign",
                "isTransparent": true
              }
            }
          },
          {
            "Javascript_BuildPayload": {
              "run": {
                "script": {
                  "code": "return { event_type: 'provider-claim-anomaly', source_system: 'provider-gamma', simulated_day: $workflow.input.simulated_day, provider_id: 'gamma', claim_drop_pct: $workflow.input.claim_drop_pct, anomaly_score: $workflow.input.anomaly_score, business_continuity_runway_days: $workflow.input.business_continuity_runway_days };",
                  "language": "javascript",
                  "arguments": "${{ \"$context\": $context, \"$workflow\": $workflow, \"$input\": $input }}"
                }
              },
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"Javascript_BuildPayload\": $output } }"
              },
              "metadata": {
                "activityType": "JsInvoke",
                "displayName": "Build Claim Anomaly Payload",
                "fullName": "JsInvoke"
              }
            }
          },
          {
            "Response_1": {
              "response": "${{ event_type: $context.outputs.Javascript_BuildPayload.event_type, source_system: $context.outputs.Javascript_BuildPayload.source_system, simulated_day: $context.outputs.Javascript_BuildPayload.simulated_day, provider_id: $context.outputs.Javascript_BuildPayload.provider_id, claim_drop_pct: $context.outputs.Javascript_BuildPayload.claim_drop_pct, anomaly_score: $context.outputs.Javascript_BuildPayload.anomaly_score, business_continuity_runway_days: $context.outputs.Javascript_BuildPayload.business_continuity_runway_days }}",
              "markJobAsFailed": false,
              "then": "end",
              "export": {
                "as": "{ ...$context, outputs: { ...$context?.outputs, \"Response_1\": $output } }"
              },
              "metadata": {
                "activityType": "Response",
                "displayName": "Response",
                "fullName": "Response"
              }
            }
          }
        ],
        "metadata": {
          "activityType": "Sequence",
          "displayName": "Sequence",
          "fullName": "Sequence"
        }
      }
    }
  ],
  "evaluate": {
    "mode": "strict",
    "language": "javascript"
  }
}
